{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CyberSkill microcopy locale file",
  "description": "Per Part 5 §7 locale pipeline + Part 14 §9 microcopy. Each locale ships a microcopy.json that conforms to this schema. Stewards translate values; the doctrine's TM + glossary integration (audit §14.14) caches translations.",
  "type": "object",
  "required": ["$locale", "$direction", "common", "errors", "empty_states", "auth"],
  "properties": {
    "$schema":          { "type": "string" },
    "$locale":          { "type": "string", "description": "BCP-47 locale tag (e.g. 'tl', 'bn', 'ur', 'pa')" },
    "$direction":       { "enum": ["ltr", "rtl"] },
    "$status":          { "type": "string", "description": "stub | reviewed | shipped" },
    "$plural_rules":    { "type": "string" },
    "$script":          { "type": "string" },
    "$canonical_source":{ "type": "string" },
    "$rtl_notes":       { "type": "string" },
    "common":           { "type": "object", "description": "save, cancel, delete, edit, close, ok, yes, no, loading, search" },
    "errors":           { "type": "object", "description": "generic, network, validation, permission" },
    "empty_states":     { "type": "object", "description": "no_results, no_data, first_run" },
    "auth":             { "type": "object", "description": "sign_in, sign_out, register, forgot_password" },
    "$cultural_notes":  { "type": "object", "description": "Locale-specific notes the steward should preserve" }
  }
}
