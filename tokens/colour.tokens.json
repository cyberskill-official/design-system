{
  "$schema": "https://design-tokens.github.io/community-group/format-2025-10/schema.json",
  "$description": "CyberSkill colour tokens — DTCG 2025.10. v1.0.0 locked 2026-04-25.",
  "color": {
    "umber":      { "$value": "#45210E", "$type": "color", "$extensions": { "com.cyberskill.oklch": "oklch(0.265 0.073 44.3)", "com.cyberskill.role": "anchor" } },
    "ochre":      { "$value": "#F4BA17", "$type": "color", "$extensions": { "com.cyberskill.oklch": "oklch(0.811 0.162 83.7)", "com.cyberskill.role": "anchor" } },
    "warm-white": { "$value": "#FAF6F1", "$type": "color" },
    "stone":      { "$value": "#8B7355", "$type": "color" },
    "surface": {
      "default": { "$value": "{color.warm-white}", "$type": "color",
        "$extensions": { "com.cyberskill.theme": { "light": "#FAF6F1", "dark": "#1C0E04", "high-contrast": "#000000", "sepia": "#F4ECDC" } } },
      "subtle":  { "$value": "#F4EFE6", "$type": "color",
        "$extensions": { "com.cyberskill.theme": { "light": "#F4EFE6", "dark": "#2A1505", "high-contrast": "#0A0A0A", "sepia": "#EAE0CB" } } },
      "raised":  { "$value": "#FFFFFF", "$type": "color",
        "$extensions": { "com.cyberskill.theme": { "light": "#FFFFFF", "dark": "#3F2515", "high-contrast": "#000000", "sepia": "#F8F1E2" } } }
    },
    "text": {
      "default": { "$value": "#2A1505", "$type": "color",
        "$extensions": { "com.cyberskill.theme": { "light": "#2A1505", "dark": "#FAF6F1", "high-contrast": "#FFFFFF", "sepia": "#3D2A14" } } },
      "muted":   { "$value": "{color.stone}", "$type": "color",
        "$extensions": { "com.cyberskill.theme": { "light": "#8B7355", "dark": "#BFAE94", "high-contrast": "#CCCCCC", "sepia": "#7C6443" } } }
    },
    "accent": {
      "default": { "$value": "{color.ochre}", "$type": "color",
        "$extensions": { "com.cyberskill.theme": { "light": "#F4BA17", "dark": "#F4BA17", "high-contrast": "#FFD400", "sepia": "#C49810" } } },
      "subtle":  { "$value": "#FBE5A6", "$type": "color" }
    },
    "border": {
      "default": { "$value": "#D7CFC0", "$type": "color",
        "$extensions": { "com.cyberskill.theme": { "light": "#D7CFC0", "dark": "#3F2515", "high-contrast": "#FFFFFF", "sepia": "#C9B895" } } },
      "subtle":  { "$value": "#EAE2D2", "$type": "color" }
    },
    "semantic": {
      "success": { "$value": "#3A7D44", "$type": "color" },
      "warning": { "$value": "#A87411", "$type": "color" },
      "danger":  { "$value": "#B33B19", "$type": "color" },
      "info":    { "$value": "#2A6CB0", "$type": "color" }
    },
    "focus-ring": { "$value": "{color.ochre}", "$type": "color" }
  }
}
