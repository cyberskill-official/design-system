{
  "$schema": "https://design-tokens.github.io/community-group/format-2025-10/schema.json",
  "$description": "Mode-aware elevation tokens. Light/dark/HC variants per surface step. Part of the Phase 1 audit-driven token-layer lifts (closes A1.4 → 4 → 5).",
  "elevation": {
    "0": {
      "$value": "none",
      "$type": "shadow",
      "$description": "Flat — no elevation. Default for in-flow content.",
      "$extensions": {
        "com.cyberskill.theme": {
          "light": "none",
          "dark": "none",
          "high-contrast": "none",
          "sepia": "none"
        }
      }
    },
    "1": {
      "$value": "0 1px 2px rgba(69, 33, 14, 0.06)",
      "$type": "shadow",
      "$description": "Subtle — borders and dividers; resting state of cards.",
      "$extensions": {
        "com.cyberskill.theme": {
          "light":          "0 1px 2px rgba(69, 33, 14, 0.06)",
          "dark":           "0 1px 2px rgba(0, 0, 0, 0.40)",
          "high-contrast":  "0 0 0 1px #FFFFFF",
          "sepia":          "0 1px 2px rgba(124, 100, 67, 0.10)"
        }
      }
    },
    "2": {
      "$value": "0 2px 6px rgba(69, 33, 14, 0.08), 0 1px 2px rgba(69, 33, 14, 0.04)",
      "$type": "shadow",
      "$description": "Lifted — hover state of cards; resting state of buttons.",
      "$extensions": {
        "com.cyberskill.theme": {
          "light":          "0 2px 6px rgba(69, 33, 14, 0.08), 0 1px 2px rgba(69, 33, 14, 0.04)",
          "dark":           "0 2px 6px rgba(0, 0, 0, 0.50), 0 1px 2px rgba(0, 0, 0, 0.30)",
          "high-contrast":  "0 0 0 2px #FFFFFF",
          "sepia":          "0 2px 6px rgba(124, 100, 67, 0.12), 0 1px 2px rgba(124, 100, 67, 0.06)"
        }
      }
    },
    "3": {
      "$value": "0 8px 16px rgba(69, 33, 14, 0.10), 0 2px 4px rgba(69, 33, 14, 0.05)",
      "$type": "shadow",
      "$description": "Floating — popovers, dropdowns, tooltips; hover on buttons.",
      "$extensions": {
        "com.cyberskill.theme": {
          "light":          "0 8px 16px rgba(69, 33, 14, 0.10), 0 2px 4px rgba(69, 33, 14, 0.05)",
          "dark":           "0 8px 16px rgba(0, 0, 0, 0.55), 0 2px 4px rgba(0, 0, 0, 0.35)",
          "high-contrast":  "0 0 0 2px #FFD400",
          "sepia":          "0 8px 16px rgba(124, 100, 67, 0.14), 0 2px 4px rgba(124, 100, 67, 0.07)"
        }
      }
    },
    "4": {
      "$value": "0 16px 32px rgba(69, 33, 14, 0.12), 0 4px 8px rgba(69, 33, 14, 0.06)",
      "$type": "shadow",
      "$description": "Modal — dialogs, sheets, command palettes.",
      "$extensions": {
        "com.cyberskill.theme": {
          "light":          "0 16px 32px rgba(69, 33, 14, 0.12), 0 4px 8px rgba(69, 33, 14, 0.06)",
          "dark":           "0 16px 32px rgba(0, 0, 0, 0.60), 0 4px 8px rgba(0, 0, 0, 0.40)",
          "high-contrast":  "0 0 0 3px #FFD400",
          "sepia":          "0 16px 32px rgba(124, 100, 67, 0.16), 0 4px 8px rgba(124, 100, 67, 0.08)"
        }
      }
    },
    "5": {
      "$value": "0 24px 48px rgba(69, 33, 14, 0.18), 0 8px 16px rgba(69, 33, 14, 0.10)",
      "$type": "shadow",
      "$description": "Overlay — toasts, notification stacks, top-most surfaces.",
      "$extensions": {
        "com.cyberskill.theme": {
          "light":          "0 24px 48px rgba(69, 33, 14, 0.18), 0 8px 16px rgba(69, 33, 14, 0.10)",
          "dark":           "0 24px 48px rgba(0, 0, 0, 0.70), 0 8px 16px rgba(0, 0, 0, 0.50)",
          "high-contrast":  "0 0 0 4px #FFD400",
          "sepia":          "0 24px 48px rgba(124, 100, 67, 0.20), 0 8px 16px rgba(124, 100, 67, 0.10)"
        }
      }
    },
    "spatial": {
      "$value": "0 32px 64px rgba(69, 33, 14, 0.24)",
      "$type": "shadow",
      "$description": "Reserved for spatial / immersive surfaces (visionOS-class glass materials). 2D fallback only; full spatial depth shipped via the depth tokens introduced by RFC 2026-006.",
      "$extensions": {
        "com.cyberskill.theme": {
          "light":          "0 32px 64px rgba(69, 33, 14, 0.24)",
          "dark":           "0 32px 64px rgba(0, 0, 0, 0.80)",
          "high-contrast":  "0 0 0 4px #FFD400",
          "sepia":          "0 32px 64px rgba(124, 100, 67, 0.28)"
        },
        "com.cyberskill.spatial": {
          "z-offset": 64,
          "material": "glass",
          "fallback": "shadow.5"
        }
      }
    }
  }
}
