# CyberSkill Design System — .gitignore
# NOTE: this HTML-first system has no build step in a plain git repo, so the
# COMPILED artifacts (_ds_bundle.js, _ds_manifest.json, _adherence.oxlintrc.json)
# are intentionally COMMITTED here — consumers load them directly. Remove those
# lines from "keep, do not ignore" only if you add a build step that regenerates them.

# Transient / local-only — do not commit
uploads/
scraps/
_audit/exports/          # heavy generated PPTX / standalone HTML proofs

# OS / editor cruft
.DS_Store
Thumbs.db
*.log
*.tmp

# Node (only if you later add tooling)
node_modules/
npm-debug.log*

# Keep (do NOT ignore): styles.css, tokens/, base/, components/, templates/,
# guidelines/, ui_kits/, fonts/, assets/, docs/, _audit/*.html (harnesses),
# and the compiled _ds_bundle.js / _ds_manifest.json / _adherence.oxlintrc.json.

# Storybook build output (regenerated by npm run build:storybook)
storybook-static/
.vercel-static/
_audit/ci/import-report.txt
