# CyberSkill Design System — .gitignore
# NOTE: this HTML-first system COMMITS its compiled artifacts (_ds_bundle.js,
# _ds_manifest.json, _adherence.oxlintrc.json) — consumers load them directly.
# _ds_bundle.js is regenerated deterministically by `npm run build:bundle`
# (scripts/build-bundle.mjs); the bundle-freshness gate keeps it in lockstep
# with component sources. _ds_manifest.json stays compiler-owned (Claude Design).

# Transient / local-only — do not commit
uploads/
scraps/
# heavy generated PPTX / standalone HTML proofs
_audit/exports/

# OS / editor cruft
.DS_Store
Thumbs.db
*.log
*.tmp

# Local AI-tool state (Claude Code permissions/worktrees)
.claude/

# Node (only if you later add tooling)
node_modules/
npm-debug.log*

# Keep (do NOT ignore): styles.css, tokens/, base/, components/, templates/,
# guidelines/, ui_kits/, fonts/, assets/, docs/, _audit/*.html (harnesses),
# and the compiled _ds_bundle.js / _ds_manifest.json / _adherence.oxlintrc.json.

# Storybook build output (regenerated by npm run build:storybook)
storybook-static/
.vercel-static/
_audit/ci/import-report.txt
_audit/ci/figma-push-report.json
_audit/ci/code-connect-report.json
_audit/ci/npm-publish-report.json
_audit/ci/pixel-diff-report.json
_audit/ci/native-store-report.json
*.tgz

# Native sample build outputs
examples/native/swiftui/.build/
examples/native/compose/.gradle/
examples/native/compose/**/build/
examples/native/compose/signing.properties
examples/native/flutter/.dart_tool/
examples/native/flutter/build/
examples/native/**/vendor/bundle/
examples/native/**/.bundle/
examples/native/**/fastlane/report.xml
examples/native/**/fastlane/Preview.html
examples/native/**/fastlane/screenshots/**/*.png
examples/native/**/*.jks
examples/native/**/*.keystore
examples/native/**/*.p8
examples/native/**/*-play-key.json
