{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/ai/**",
              "components/brand/**",
              "components/button/**",
              "components/data/**",
              "components/datatable/**",
              "components/dialog/**",
              "components/feedback/**",
              "components/forms/**",
              "components/icon/**",
              "components/logo/**",
              "components/navigation/**",
              "components/overlays/**",
              "components/textfield/**",
              "image-slot.js",
              "tokens/**",
              "ui_kits/status-hub/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Be Vietnam Pro|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Be Vietnam Pro, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccordionEntry'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|content|key|ref|className|style|children)$/]",
        "message": "<AccordionEntry> doesn't accept that prop. Declared props: title, content."
      },
      {
        "selector": "JSXOpeningElement[name.name='AIDisclosureBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|details|sources|className|key|ref|className|style|children)$/]",
        "message": "<AIDisclosureBadge> doesn't accept that prop. Declared props: label, details, sources, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|icon|children|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: variant, title, icon, children."
