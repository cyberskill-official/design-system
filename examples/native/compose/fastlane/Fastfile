# CyberSkill Compose sample — Play Store packaging scaffold.
# Samples remain samples until product need. Do NOT submit from CI in this program.
#
# Lanes:
#   release_dry_run  — print plan; no signing, no upload
#   build_release    — assembleRelease when keystore + SDK exist (not wired in CI submit)
#   metadata_lint    — ensure listing placeholders exist

default_platform(:android)

REQUIRED_METADATA = %w[
  title.txt
  short_description.txt
  full_description.txt
].freeze

platform :android do
  desc "Dry-run: verify listing metadata + print release plan (no secrets, no upload)"
  lane :release_dry_run do
    metadata_lint
    UI.success("Compose sample store dry-run OK — would assembleRelease+supply when Play JSON + keystore exist")
    UI.message("package_name: world.cyberskill.sample")
    UI.message("CI Decision 1C: soft-skip without PLAY_SERVICE_ACCOUNT_JSON (+ optional ANDROID_KEYSTORE_*)")
  end

  desc "Assert Play Store listing placeholders are present"
  lane :metadata_lint do
    base = File.join(FastlaneCore::FastlaneFolder.path, "metadata", "android", "en-US")
    REQUIRED_METADATA.each do |f|
      path = File.join(base, f)
      UI.user_error!("Missing metadata: #{path}") unless File.exist?(path)
      UI.user_error!("Empty metadata: #{path}") if File.read(path).strip.empty?
    end
    changelog = File.join(base, "changelogs", "1.txt")
    UI.user_error!("Missing changelog: #{changelog}") unless File.exist?(changelog)
    UI.success("metadata/android/en-US placeholders present")
  end

  desc "Build release AAB/APK — requires Android SDK + signing.properties (not auto-submitted)"
  lane :build_release do
    UI.important("Copy signing.properties.example → signing.properties and set ANDROID_KEYSTORE_* first.")
    gradle(
      task: "assembleRelease",
      project_dir: File.expand_path("..", FastlaneCore::FastlaneFolder.path)
    )
  end

  desc "Upload to Play Console — DISABLED for samples (never call from CI)"
  lane :upload_store do
    UI.user_error!("Store submit disabled — samples remain samples until product need")
  end
end
