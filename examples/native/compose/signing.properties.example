# Copy to signing.properties (gitignored) when building a signed release AAB.
# Never commit real keystore paths or passwords.
#
# CI soft-skips without these (Decision 1C). Optional secrets for a local/CI signed build:
#   ANDROID_KEYSTORE_BASE64 | ANDROID_KEYSTORE_PATH
#   ANDROID_KEYSTORE_PASSWORD
#   ANDROID_KEY_ALIAS
#   ANDROID_KEY_PASSWORD

storeFile=/absolute/path/to/cyberskill-sample.jks
storePassword=REPLACE_ME
keyAlias=cyberskill
keyPassword=REPLACE_ME
