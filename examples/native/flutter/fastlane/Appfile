# Store identity placeholders — fill when promoting this sample to a real product.
# CI soft-skips without ASC_* (iOS) and PLAY_SERVICE_ACCOUNT_JSON (Android). Decision 1C.

app_identifier("world.cyberskill.sample")
apple_id(ENV["ASC_APPLE_ID"] || "REPLACE_WITH_APPLE_ID")
team_id(ENV["ASC_TEAM_ID"] || "REPLACE_WITH_TEAM_ID")

for_platform :android do
  json_key_file(ENV["PLAY_SERVICE_ACCOUNT_JSON"] || "REPLACE_WITH_PLAY_JSON_KEY_PATH")
  package_name("world.cyberskill.sample")
end
