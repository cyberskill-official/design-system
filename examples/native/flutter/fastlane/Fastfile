# CyberSkill Flutter sample — App Store / Play Store packaging scaffold.
# Samples remain samples until product need. Do NOT submit from CI in this program.
#
# Lanes:
#   release_dry_run  — lint metadata for both stores; no signing, no upload
#   build_ios / build_android — flutter build when toolchains exist (not auto-submitted)

REQUIRED_IOS = %w[
  name.txt
  subtitle.txt
  description.txt
  keywords.txt
  release_notes.txt
  privacy_url.txt
  support_url.txt
  marketing_url.txt
].freeze

REQUIRED_ANDROID = %w[
  title.txt
  short_description.txt
  full_description.txt
].freeze

desc "Dry-run: verify iOS + Android metadata placeholders (no secrets, no upload)"
lane :release_dry_run do
  metadata_lint
  UI.success("Flutter sample store dry-run OK — would flutter build ipa/appbundle when secrets + SDK exist")
  UI.message("CI Decision 1C: soft-skip without ASC_* and/or PLAY_SERVICE_ACCOUNT_JSON")
end

desc "Assert store listing placeholders for both platforms"
lane :metadata_lint do
  ios_base = File.join(FastlaneCore::FastlaneFolder.path, "metadata", "ios", "en-US")
  REQUIRED_IOS.each do |f|
    path = File.join(ios_base, f)
    UI.user_error!("Missing iOS metadata: #{path}") unless File.exist?(path)
    UI.user_error!("Empty iOS metadata: #{path}") if File.read(path).strip.empty?
  end
  and_base = File.join(FastlaneCore::FastlaneFolder.path, "metadata", "android", "en-US")
  REQUIRED_ANDROID.each do |f|
    path = File.join(and_base, f)
    UI.user_error!("Missing Android metadata: #{path}") unless File.exist?(path)
    UI.user_error!("Empty Android metadata: #{path}") if File.read(path).strip.empty?
  end
  changelog = File.join(and_base, "changelogs", "1.txt")
  UI.user_error!("Missing Android changelog: #{changelog}") unless File.exist?(changelog)
  UI.success("Flutter iOS + Android metadata placeholders present")
end

desc "flutter build ipa — requires Flutter SDK + signing (not auto-submitted)"
lane :build_ios do
  sh("flutter", "build", "ipa", "--release")
end

desc "flutter build appbundle — requires Flutter SDK + signing (not auto-submitted)"
lane :build_android do
  sh("flutter", "build", "appbundle", "--release")
end

desc "Upload to stores — DISABLED for samples (never call from CI)"
lane :upload_store do
  UI.user_error!("Store submit disabled — samples remain samples until product need")
end
