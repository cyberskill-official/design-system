# CyberSkill SwiftUI sample — App Store packaging scaffold.
# Samples remain samples until product need. Do NOT submit from CI in this program.
#
# Lanes:
#   release_dry_run  — print plan; no signing, no upload
#   build_release    — archive when an Xcode app target + certs exist (not wired in CI submit)
#   metadata_lint    — ensure metadata placeholders exist

default_platform(:ios)

REQUIRED_METADATA = %w[
  name.txt
  subtitle.txt
  description.txt
  keywords.txt
  release_notes.txt
  privacy_url.txt
  support_url.txt
  marketing_url.txt
].freeze

platform :ios do
  desc "Dry-run: verify metadata + print release plan (no secrets, no upload)"
  lane :release_dry_run do
    metadata_lint
    UI.success("SwiftUI sample store dry-run OK — would gym+deliver when ASC_* + Xcode app target exist")
    UI.message("app_identifier: world.cyberskill.sample (placeholder)")
    UI.message("CI Decision 1C: soft-skip without ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_P8")
  end

  desc "Assert App Store metadata placeholders are present"
  lane :metadata_lint do
    base = File.join(FastlaneCore::FastlaneFolder.path, "metadata", "en-US")
    REQUIRED_METADATA.each do |f|
      path = File.join(base, f)
      UI.user_error!("Missing metadata: #{path}") unless File.exist?(path)
      UI.user_error!("Empty metadata: #{path}") if File.read(path).strip.empty?
    end
    UI.success("metadata/en-US placeholders present (#{REQUIRED_METADATA.length} files)")
  end

  desc "Build release archive — requires Xcode app scheme + signing (not auto-submitted)"
  lane :build_release do
    UI.important("This SPM sample has no App Store Xcode project yet.")
    UI.important("Promote to a product Xcode app, then uncomment gym below.")
    # gym(
    #   scheme: "CyberSkillSample",
    #   export_method: "app-store",
    #   clean: true,
    # )
    UI.user_error!("build_release not configured — sample scaffold only")
  end

  desc "Upload to App Store Connect — DISABLED for samples (never call from CI)"
  lane :upload_store do
    UI.user_error!("Store submit disabled — samples remain samples until product need")
  end
end
