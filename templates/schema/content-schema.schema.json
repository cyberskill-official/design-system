{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CyberSkill template content-schema v2",
  "type": "object",
  "required": ["$schemaVersion", "template", "slots"],
  "properties": {
    "$schemaVersion": { "const": "2.0" },
    "template": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "slots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "label"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
          "type": { "enum": ["text", "richtext", "image", "link", "list", "table", "date"] },
          "label": { "type": "string", "minLength": 1 },
          "maxLength": { "type": "integer", "minimum": 1 },
          "required": { "type": "boolean" },
          "i18n": {
            "type": "object",
            "properties": { "en": { "type": "string" }, "vi": { "type": "string" } }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
