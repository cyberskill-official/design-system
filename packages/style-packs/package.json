{
  "name": "@cyberskill/style-packs",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "description": "Separately-stored CyberSkill style packs (skins). Each pack layers render-surface decisions over the immutable Umber + Ochre anchors. Selected at runtime via data-cs-style.",
  "exports": {
    "./registry": "./dist/registry.json",
    "./css": "./dist/style-packs.css"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "verify": "node scripts/verify.mjs",
    "gallery": "node scripts/build-gallery.mjs",
    "screenshot": "node scripts/build-gallery.mjs && playwright test -c playwright.config.mjs",
    "screenshot:update": "node scripts/build-gallery.mjs && playwright test -c playwright.config.mjs --update-snapshots",
    "prepublishOnly": "node scripts/build.mjs && node scripts/verify.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
