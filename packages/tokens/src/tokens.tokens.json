{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "CyberSkill prototype DTCG token source. Prototype artifact: not GA.",
  "cs": {
    "color": {
      "brand": {
        "umber": {
          "$type": "color",
          "$value": "#45210E",
          "$description": "Primary brand anchor: Umber. Immutable.",
          "$extensions": {
            "com.cyberskill.immutable": true,
            "com.cyberskill.oklch": "oklch(0.265 0.073 44.3)"
          }
        },
        "ochre": {
          "$type": "color",
          "$value": "#F4BA17",
          "$description": "Primary brand accent: Ochre. Immutable.",
          "$extensions": {
            "com.cyberskill.immutable": true,
            "com.cyberskill.oklch": "oklch(0.811 0.162 83.7)"
          }
        }
      },
      "surface": {
        "page": {
          "$type": "color",
          "$value": "#FFFDF8",
          "$description": "Default page background."
        },
        "panel": {
          "$type": "color",
          "$value": "#FFFFFF",
          "$description": "Default panel background."
        },
        "raised": {
          "$type": "color",
          "$value": "#FBF4E9",
          "$description": "Subtly raised surface (hover/secondary fill)."
        }
      },
      "text": {
        "primary": {
          "$type": "color",
          "$value": "{cs.color.brand.umber}",
          "$description": "Primary text color."
        },
        "inverse": {
          "$type": "color",
          "$value": "#FFFFFF",
          "$description": "Inverse text color."
        },
        "accent": {
          "$type": "color",
          "$value": "#6E3B0E",
          "$description": "Accessible ochre-adjacent text accent."
        },
        "muted": {
          "$type": "color",
          "$value": "#6E5A4C",
          "$description": "Muted/secondary text. APCA-safe on surface.page."
        }
      },
      "semantic": {
        "success": {
          "$type": "color",
          "$value": "#166534",
          "$description": "Success foreground."
        },
        "danger": {
          "$type": "color",
          "$value": "#B42318",
          "$description": "Danger foreground."
        },
        "warning": {
          "$type": "color",
          "$value": "#92400E",
          "$description": "Warning foreground."
        },
        "info": {
          "$type": "color",
          "$value": "#1D4ED8",
          "$description": "Info foreground."
        }
      },
      "accent": {
        "ochre": {
          "$type": "color",
          "$value": "{cs.color.brand.ochre}",
          "$description": "Accent alias of Ochre, used for focus rings."
        }
      },
      "border": {
        "default": {
          "$type": "color",
          "$value": "#E7D9C6",
          "$description": "Default hairline border (warm neutral). Used by glass material edges and solid surfaces."
        }
      }
    },
    "space": {
      "0": {
        "$type": "dimension",
        "$value": "0px",
        "$description": "Zero spacing."
      },
      "1": {
        "$type": "dimension",
        "$value": "4px",
        "$description": "4px spacing step."
      },
      "2": {
        "$type": "dimension",
        "$value": "8px",
        "$description": "8px spacing step."
      },
      "3": {
        "$type": "dimension",
        "$value": "12px",
        "$description": "12px spacing step."
      },
      "4": {
        "$type": "dimension",
        "$value": "16px",
        "$description": "16px spacing step."
      },
      "5": {
        "$type": "dimension",
        "$value": "20px",
        "$description": "20px spacing step."
      },
      "6": {
        "$type": "dimension",
        "$value": "24px",
        "$description": "24px spacing step."
      },
      "8": {
        "$type": "dimension",
        "$value": "32px",
        "$description": "32px spacing step."
      },
      "10": {
        "$type": "dimension",
        "$value": "40px",
        "$description": "40px spacing step."
      },
      "12": {
        "$type": "dimension",
        "$value": "48px",
        "$description": "48px spacing step."
      },
      "16": {
        "$type": "dimension",
        "$value": "64px",
        "$description": "64px spacing step (section padding floor)."
      },
      "20": {
        "$type": "dimension",
        "$value": "80px",
        "$description": "80px spacing step."
      },
      "24": {
        "$type": "dimension",
        "$value": "96px",
        "$description": "96px spacing step (section padding ceiling)."
      }
    },
    "radius": {
      "sm": {
        "$type": "dimension",
        "$value": "4px",
        "$description": "Small radius."
      },
      "md": {
        "$type": "dimension",
        "$value": "8px",
        "$description": "Default radius."
      },
      "full": {
        "$type": "dimension",
        "$value": "999px",
        "$description": "Pill radius."
      }
    },
    "font": {
      "family": {
        "ui": {
          "$type": "fontFamily",
          "$value": "Be Vietnam Pro, ui-sans-serif, system-ui",
          "$description": "Primary UI font stack."
        },
        "mono": {
          "$type": "fontFamily",
          "$value": "JetBrains Mono, ui-monospace, SFMono-Regular, Menlo, Consolas",
          "$description": "Primary code font stack."
        }
      },
      "lineHeight": {
        "body": {
          "$type": "number",
          "$value": 1.5,
          "$description": "Vietnamese-safe body line height."
        },
        "heading": {
          "$type": "number",
          "$value": 1.35,
          "$description": "Vietnamese-safe heading line height."
        }
      }
    },
    "component": {
      "button": {
        "primary": {
          "bg": {
            "$type": "color",
            "$value": "{cs.color.brand.umber}",
            "$description": "Button primary background."
          },
          "fg": {
            "$type": "color",
            "$value": "{cs.color.text.inverse}",
            "$description": "Button primary foreground."
          }
        },
        "gap": {
          "$type": "dimension",
          "$value": "8px",
          "$description": "Gap between button icon and label."
        },
        "radius": {
          "$type": "dimension",
          "$value": "{cs.radius.md}",
          "$description": "Button corner radius."
        },
        "sm": {
          "paddingY": {
            "$type": "dimension",
            "$value": "8px",
            "$description": "Compact button. Vertical padding."
          },
          "paddingX": {
            "$type": "dimension",
            "$value": "14px",
            "$description": "Compact button. Horizontal padding."
          },
          "minHeight": {
            "$type": "dimension",
            "$value": "36px",
            "$description": "Compact button. Minimum height / touch target."
          }
        },
        "md": {
          "paddingY": {
            "$type": "dimension",
            "$value": "12px",
            "$description": "Default button (comfortable touch target). Vertical padding."
          },
          "paddingX": {
            "$type": "dimension",
            "$value": "20px",
            "$description": "Default button (comfortable touch target). Horizontal padding."
          },
          "minHeight": {
            "$type": "dimension",
            "$value": "44px",
            "$description": "Default button (comfortable touch target). Minimum height / touch target."
          }
        },
        "lg": {
          "paddingY": {
            "$type": "dimension",
            "$value": "16px",
            "$description": "Prominent CTA button. Vertical padding."
          },
          "paddingX": {
            "$type": "dimension",
            "$value": "28px",
            "$description": "Prominent CTA button. Horizontal padding."
          },
          "minHeight": {
            "$type": "dimension",
            "$value": "52px",
            "$description": "Prominent CTA button. Minimum height / touch target."
          }
        }
      },
      "textfield": {
        "border": {
          "default": {
            "$type": "color",
            "$value": "#BFA58F",
            "$description": "TextField default border."
          }
        },
        "paddingY": {
          "$type": "dimension",
          "$value": "10px",
          "$description": "TextField vertical padding."
        },
        "paddingX": {
          "$type": "dimension",
          "$value": "12px",
          "$description": "TextField horizontal padding."
        },
        "minHeight": {
          "$type": "dimension",
          "$value": "44px",
          "$description": "TextField minimum height / touch target."
        }
      }
    },
    "breakpoint": {
      "xs": {
        "$type": "dimension",
        "$value": "0px",
        "$description": "Base mobile breakpoint (mobile-first)."
      },
      "sm": {
        "$type": "dimension",
        "$value": "640px",
        "$description": "Small / large-phone breakpoint."
      },
      "md": {
        "$type": "dimension",
        "$value": "768px",
        "$description": "Tablet breakpoint."
      },
      "lg": {
        "$type": "dimension",
        "$value": "1024px",
        "$description": "Laptop / small-desktop breakpoint."
      },
      "xl": {
        "$type": "dimension",
        "$value": "1280px",
        "$description": "Desktop breakpoint."
      },
      "2xl": {
        "$type": "dimension",
        "$value": "1536px",
        "$description": "Wide-desktop breakpoint."
      }
    },
    "depth": {
      "bg": {
        "$type": "number",
        "$value": 0,
        "$description": "Z-axis depth: page background / hero washes (Part 21 §21.5)."
      },
      "section": {
        "$type": "number",
        "$value": 5,
        "$description": "Z-axis depth: major page sections (matte; no glass)."
      },
      "card": {
        "$type": "number",
        "$value": 10,
        "$description": "Z-axis depth: cards/panels (Standard Glass when opted in)."
      },
      "nav": {
        "$type": "number",
        "$value": 50,
        "$description": "Z-axis depth: sticky top/side nav (Light Glass)."
      },
      "modal": {
        "$type": "number",
        "$value": 100,
        "$description": "Z-axis depth: modals, dialogs, command palette (Heavy Glass)."
      },
      "toast": {
        "$type": "number",
        "$value": 200,
        "$description": "Z-axis depth: toasts, popovers, dropdowns, tooltips (Heavy Glass)."
      }
    },
    "glass": {
      "whisper": {
        "blur": {
          "$type": "dimension",
          "$value": "8px",
          "$description": "Whisper Glass backdrop blur radius (ambient backgrounds/hero washes)."
        },
        "saturate": {
          "$type": "number",
          "$value": "110%",
          "$description": "Whisper Glass backdrop saturation."
        },
        "opacity": {
          "$type": "number",
          "$value": "60%",
          "$description": "Whisper Glass surface opacity (color-mix amount of base surface vs transparent)."
        }
      },
      "light": {
        "blur": {
          "$type": "dimension",
          "$value": "12px",
          "$description": "Light Glass backdrop blur radius (sticky navs, sidebars)."
        },
        "saturate": {
          "$type": "number",
          "$value": "130%",
          "$description": "Light Glass backdrop saturation."
        },
        "opacity": {
          "$type": "number",
          "$value": "70%",
          "$description": "Light Glass surface opacity."
        }
      },
      "standard": {
        "blur": {
          "$type": "dimension",
          "$value": "16px",
          "$description": "Standard Glass backdrop blur radius (sparse cards, AI overlays)."
        },
        "saturate": {
          "$type": "number",
          "$value": "150%",
          "$description": "Standard Glass backdrop saturation."
        },
        "opacity": {
          "$type": "number",
          "$value": "80%",
          "$description": "Standard Glass surface opacity."
        }
      },
      "heavy": {
        "blur": {
          "$type": "dimension",
          "$value": "24px",
          "$description": "Heavy Glass backdrop blur radius (modals, popovers, toasts)."
        },
        "saturate": {
          "$type": "number",
          "$value": "180%",
          "$description": "Heavy Glass backdrop saturation."
        },
        "opacity": {
          "$type": "number",
          "$value": "90%",
          "$description": "Heavy Glass surface opacity."
        }
      }
    }
  }
}
