{
  "name": "@cyberskill/web-components",
  "version": "1.0.0",
  "description": "Styled custom elements (cs-button, cs-input, ...) for the CyberSkill Design System. Per RFC 2026-003.",
  "type": "module",
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./button": "./src/cs-button.mjs",
    "./input": "./src/cs-input.mjs",
    "./checkbox": "./src/cs-checkbox.mjs",
    "./radio": "./src/cs-radio.mjs",
    "./toggle": "./src/cs-toggle.mjs",
    "./card": "./src/cs-card.mjs",
    "./modal": "./src/cs-modal.mjs",
    "./toast": "./src/cs-toast.mjs",
    "./tabs": "./src/cs-tabs.mjs",
    "./table": "./src/cs-table.mjs",
    "./nav": "./src/cs-nav.mjs",
    "./select": "./src/cs-select.mjs",
    "./loader": "./src/loader.mjs"
  },
  "files": ["src", "README.md"],
  "scripts": {
    "build": "echo 'No build step — web-components ship as ESM source. Wave 2 adds bundling.'"
  },
  "dependencies": {
    "@cyberskill/primitives": "workspace:*",
    "@cyberskill/tokens": "workspace:*"
  },
  "keywords": ["web-components", "custom-elements", "design-system"],
  "license": "MIT"
}
