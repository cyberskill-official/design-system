{
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run build:site",
  "outputDirectory": ".vercel-static",
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/dashboard",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/dashboard/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/dashboard.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/dashboard/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/playground",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/playground/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/playground/:path*",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob:; connect-src 'self' https://unpkg.com https://cdnjs.cloudflare.com; frame-src 'self'; worker-src 'self' blob:; base-uri 'self'; form-action 'self'"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
