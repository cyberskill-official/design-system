{
  "name": "cyberskill-design-system",
  "version": "1.5.1-artifact.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "scripts": {
    "tokens:build": "node packages/tokens/scripts/build.mjs",
    "stylepacks:build": "node packages/style-packs/scripts/build.mjs",
    "stylepacks:gallery": "node packages/style-packs/scripts/build-gallery.mjs",
    "stylepacks:screenshot": "npm run stylepacks:gallery && playwright test -c packages/style-packs/playwright.config.mjs",
    "stylepacks:screenshot:update": "npm run stylepacks:gallery && playwright test -c packages/style-packs/playwright.config.mjs --update-snapshots",
    "components:test": "node packages/react/test/component-contracts.test.mjs",
    "components:render": "node packages/react/test/render-smoke.test.mjs",
    "artifacts": "node scripts/generate-artifacts.mjs",
    "verify": "node scripts/verify-artifacts.mjs",
    "audit": "node scripts/audit.mjs",
    "audit:baseline": "node scripts/audit.mjs --baseline",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "stylepacks:verify": "node packages/style-packs/scripts/verify.mjs",
    "verify:all": "npm run tokens:build && npm run stylepacks:build && npm run stylepacks:verify && npm run components:test && npm run components:render && npm run check:bundle-size && npm run verify",
    "test": "npm run verify:all"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
