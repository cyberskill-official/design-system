{
  "name": "cyberskill-design-system",
  "version": "1.0.0",
  "private": true,
  "module": "_esm/cs.mjs",
  "exports": {
    ".": {
      "import": "./_esm/cs.mjs"
    },
    "./styles.css": "./styles.css",
    "./tokens/*": "./tokens/*"
  },
  "description": "CyberSkill Design System \u2014 HTML-first, Vietnamese-first (EN\u00b7VI). Anchors: Umber #45210E \u00b7 Ochre #F4BA17. Axes: Theme \u00d7 Element \u00d7 Language. No build step: styles.css + _ds_bundle.js. Storybook is host-only playground.",
  "style": "styles.css",
  "files": [
    "styles.css",
    "_esm/",
    "tokens/",
    "base/",
    "fonts/",
    "assets/",
    "_ds_bundle.js",
    "_ds_manifest.json",
    "llms.txt",
    "SKILL.md",
    "docs/",
    "components/",
    "templates/",
    "guidelines/",
    "ui_kits/"
  ],
  "keywords": [
    "design-system",
    "design-tokens",
    "bilingual",
    "vietnamese",
    "cyberskill"
  ],
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build:bundle": "node scripts/build-bundle.mjs",
    "build:design-md": "node scripts/generate-design-md.mjs",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build -o storybook-static",
    "build:site": "npm run build:storybook && node scripts/vercel-static-output.mjs",
    "verify:serve": "python3 -m http.server 8765 --bind 127.0.0.1",
    "verify:hint": "echo Open http://127.0.0.1:8765/_audit/run.html and wait for ALL hard gates PASS",
    "verify:local": "bash scripts/verify-local.sh",
    "test:nav-model": "node _audit/ci/test-nav-model.mjs",
    "test:ui-contracts": "node _audit/ci/test-health-tokens-contract.mjs",
    "test:form-paths": "node _audit/ci/test-form-paths.mjs",
    "test:unit": "node _audit/ci/test-nav-model.mjs && node _audit/ci/test-health-tokens-contract.mjs && node _audit/ci/test-form-paths.mjs && node _audit/ci/test-storybook-contract.mjs && node _audit/ci/test-figma-push-helpers.mjs && node _audit/ci/test-native-samples.mjs",
    "native:sync-tokens": "node examples/native/sync-tokens.mjs",
    "test:storybook-contract": "node _audit/ci/test-storybook-contract.mjs",
    "test:storybook-coverage": "node _audit/ci/test-storybook-contract.mjs",
    "test:figma-helpers": "node _audit/ci/test-figma-push-helpers.mjs",
    "test:native-samples": "node _audit/ci/test-native-samples.mjs"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.28.1",
    "playwright": "^1.47.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.11",
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/react": "^10.5.3",
    "@storybook/react-vite": "^10.5.3",
    "storybook": "^10.5.3"
  }
}
