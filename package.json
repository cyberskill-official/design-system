{
  "name": "@cyberskill/design",
  "version": "1.0.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyberskill-official/design-system.git"
  },
  "module": "_esm/cs.mjs",
  "exports": {
    ".": {
      "import": "./_esm/cs.mjs"
    },
    "./styles.css": "./styles.css",
    "./tokens/*": "./tokens/*",
    "./_ds_bundle.js": "./_ds_bundle.js",
    "./_ds_manifest.json": "./_ds_manifest.json"
  },
  "description": "CyberSkill Design System — HTML-first, Vietnamese-first (EN·VI). Anchors: Umber #45210E · Ochre #F4BA17. Axes: Theme × Element × Language. No build step: styles.css + _ds_bundle.js. Storybook is host-only playground.",
  "style": "styles.css",
  "files": [
    "styles.css",
    "_esm/",
    "tokens/",
    "base/",
    "fonts/",
    "assets/",
    "_ds_bundle.js",
    "_ds_manifest.json",
    "llms.txt",
    "SKILL.md",
    "docs/",
    "components/",
    "templates/",
    "guidelines/",
    "ui_kits/",
    "DESIGN.md",
    "VERSION"
  ],
  "keywords": [
    "design-system",
    "design-tokens",
    "bilingual",
    "vietnamese",
    "cyberskill"
  ],
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build:bundle": "node scripts/build-bundle.mjs",
    "build:design-md": "node scripts/generate-design-md.mjs",
    "prepublishOnly": "npm run build:bundle && node scripts/generate-design-md.mjs --check",
    "code-connect:generate": "node _audit/ci/generate-code-connect.mjs",
    "code-connect:dry-run": "node _audit/ci/code-connect-publish.mjs --dry-run",
    "npm:pack-dry-run": "node _audit/ci/npm-publish.mjs --dry-run",
    "native:store-dry-run": "node _audit/ci/native-store-dry-run.mjs --dry-run",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build -o storybook-static",
    "build:site": "npm run build:storybook && node scripts/vercel-static-output.mjs",
    "verify:serve": "python3 -m http.server 8765 --bind 127.0.0.1",
    "verify:hint": "echo Open http://127.0.0.1:8765/_audit/run.html and wait for ALL hard gates PASS",
    "verify:local": "bash scripts/verify-local.sh",
    "test:nav-model": "node _audit/ci/test-nav-model.mjs",
    "test:ui-contracts": "node _audit/ci/test-health-tokens-contract.mjs",
    "test:form-paths": "node _audit/ci/test-form-paths.mjs",
    "test:unit": "node _audit/ci/test-nav-model.mjs && node _audit/ci/test-health-tokens-contract.mjs && node _audit/ci/test-form-paths.mjs && node _audit/ci/test-storybook-contract.mjs && node _audit/ci/test-figma-push-helpers.mjs && node _audit/ci/test-native-samples.mjs && node _audit/ci/test-code-connect.mjs && node _audit/ci/test-subtree-consume.mjs",
    "test:subtree-consume": "node _audit/ci/test-subtree-consume.mjs",
    "native:sync-tokens": "node examples/native/sync-tokens.mjs",
    "test:storybook-contract": "node _audit/ci/test-storybook-contract.mjs",
    "test:storybook-coverage": "node _audit/ci/test-storybook-contract.mjs",
    "test:figma-helpers": "node _audit/ci/test-figma-push-helpers.mjs",
    "test:code-connect": "node _audit/ci/test-code-connect.mjs",
    "test:native-samples": "node _audit/ci/test-native-samples.mjs"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.4.9",
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/react": "^10.5.3",
    "@storybook/react-vite": "^10.5.3",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.28.1",
    "playwright": "^1.47.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.5.3",
    "vite": "^5.4.11"
  }
}
